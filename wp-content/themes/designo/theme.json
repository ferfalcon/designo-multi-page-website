{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "color": "#E7816B",
          "name": "Peach",
          "slug": "peach"
        },
        {
          "color": "#FFAD9B",
          "name": "Light Peach",
          "slug": "light-peach"
        },
        {
          "color": "#1D1C1E",
          "name": "Black",
          "slug": "black"
        },
        {
          "color": "#333136",
          "name": "Dark Grey",
          "slug": "dark-grey"
        },
        {
          "color": "#F1F3F5",
          "name": "Light Grey",
          "slug": "light-grey"
        },
        {
          "color": "#FDF3F0",
          "name": "Pale Peach",
          "slug": "pale-peach"
        },
        {
          "color": "#FFFFFF",
          "name": "White",
          "slug": "white"
        }
      ]
    },
    "layout": {
      "contentSize": "690px",
      "wideSize": "1110px"
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "name": "2X Small",
          "size": "0.5rem",
          "slug": "20"
        },
        {
          "name": "X Small",
          "size": "1rem",
          "slug": "30"
        },
        {
          "name": "Small",
          "size": "1.5rem",
          "slug": "40"
        },
        {
          "name": "Medium",
          "size": "2rem",
          "slug": "50"
        },
        {
          "name": "Large",
          "size": "clamp(3rem, 7vw, 5rem)",
          "slug": "60"
        },
        {
          "name": "X Large",
          "size": "clamp(4rem, 9vw, 7.5rem)",
          "slug": "70"
        },
        {
          "name": "2X Large",
          "size": "clamp(6rem, 12vw, 10rem)",
          "slug": "80"
        }
      ],
      "units": [
        "%",
        "px",
        "em",
        "rem",
        "vh",
        "vw"
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "Jost, Arial, sans-serif",
          "name": "Jost",
          "slug": "jost"
        }
      ],
      "fontSizes": [
        {
          "fluid": false,
          "name": "Small",
          "size": "0.875rem",
          "slug": "small"
        },
        {
          "fluid": false,
          "name": "Base",
          "size": "1rem",
          "slug": "base"
        },
        {
          "fluid": {
            "max": "1.25rem",
            "min": "1.125rem"
          },
          "name": "Lead",
          "size": "1.125rem",
          "slug": "lead"
        },
        {
          "fluid": {
            "max": "2rem",
            "min": "1.75rem"
          },
          "name": "Heading 2",
          "size": "2rem",
          "slug": "heading-2"
        },
        {
          "fluid": {
            "max": "3rem",
            "min": "2rem"
          },
          "name": "Heading 1",
          "size": "3rem",
          "slug": "heading-1"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var:preset|color|white",
      "text": "var:preset|color|dark-grey"
    },
    "elements": {
      "button": {
        ":hover": {
          "color": {
            "background": "var:preset|color|light-peach",
            "text": "var:preset|color|white"
          }
        },
        "border": {
          "radius": "8px"
        },
        "color": {
          "background": "var:preset|color|white",
          "text": "var:preset|color|dark-grey"
        },
        "spacing": {
          "padding": {
            "bottom": "1.05rem",
            "left": "1.55rem",
            "right": "1.55rem",
            "top": "1.05rem"
          }
        },
        "typography": {
          "fontSize": "0.9375rem",
          "fontWeight": "500",
          "letterSpacing": "0.0667em",
          "textTransform": "uppercase"
        }
      },
      "heading": {
        "color": {
          "text": "var:preset|color|dark-grey"
        },
        "typography": {
          "fontWeight": "500",
          "letterSpacing": "0"
        }
      },
      "link": {
        ":hover": {
          "color": {
            "text": "var:preset|color|peach"
          }
        },
        "color": {
          "text": "currentColor"
        },
        "typography": {
          "textDecoration": "none"
        }
      }
    },
    "spacing": {
      "blockGap": "var:preset|spacing|50",
      "padding": {
        "left": "24px",
        "right": "24px"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|jost",
      "fontSize": "var:preset|font-size|base",
      "fontWeight": "400",
      "lineHeight": "1.625"
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "8px"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "0.875rem",
          "letterSpacing": "0.143em",
          "textTransform": "uppercase"
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ]
}
